VITE_PORT=3000

# DOCKER
DOCKER_DATABASE_PORT="5432"
DOCKER_DATABASE_NAME="startui"
DOCKER_DATABASE_USERNAME="startui"
DOCKER_DATABASE_PASSWORD="startui"

DOCKER_MINIO_API_PORT="9000"
DOCKER_MINIO_UI_PORT="9001"
DOCKER_MINIO_USERNAME="minioadmin"
DOCKER_MINIO_PASSWORD="minioadmin"
DOCKER_OTEL_COLLECTOR_PORT="4318"

# BASE URL
VITE_BASE_URL="http://localhost:${VITE_PORT}"

# S3
S3_BUCKET_NAME="default"
S3_HOST="127.0.0.1:${DOCKER_MINIO_API_PORT}"
S3_ACCESS_KEY_ID="startui-access-key"
S3_SECRET_ACCESS_KEY="startui-secret-key"
S3_SECURE=false
S3_FORCE_PATH_STYLE=true
VITE_S3_BUCKET_PUBLIC_URL="http://${S3_HOST}/${S3_BUCKET_NAME}"

# Use the following environment variables to show the environment name.
VITE_ENV_NAME="LOCAL"
VITE_ENV_EMOJI="🚧"
VITE_ENV_COLOR="gold"

# Configure demo mode (read only)
VITE_IS_DEMO="false"
VITE_VISUAL_TEST="false"

# DATABASE
DATABASE_URL="postgres://${DOCKER_DATABASE_USERNAME}:${DOCKER_DATABASE_PASSWORD}@localhost:${DOCKER_DATABASE_PORT}/${DOCKER_DATABASE_NAME}"
DATABASE_DRIVER="node-pg" # node-pg, neon-http, or neon-websocket; neon-http uses WebSocket for interactive transactions
# Optional maintenance connection for migrations. Defaults to DATABASE_URL when it is not transaction-pooled.
# DATABASE_MIGRATION_URL="postgres://${DOCKER_DATABASE_USERNAME}:${DOCKER_DATABASE_PASSWORD}@localhost:${DOCKER_DATABASE_PORT}/${DOCKER_DATABASE_NAME}"
# DATABASE_MIGRATION_DRIVER="node-pg" # node-pg or neon-websocket; neon-http migrations are rejected

# AUTH
AUTH_PROVIDER="better-auth" # better-auth for now; workos is reserved for the later AuthKit migration
AUTH_SECRET="REPLACE ME" # You can use `npx @better-auth/cli@latest secret` to a generated secret
# AUTH_ALLOWED_HOSTS="*.vercel.app" # Comma-separated list of allowed hosts for dynamic base URL (https://better-auth.com/docs/concepts/dynamic-base-url)
AUTH_SESSION_EXPIRATION_IN_SECONDS=2592000 # 30 days
AUTH_SESSION_UPDATE_AGE_IN_SECONDS=86400 # 1 day (every 1 day the session expiration is updated)
AUTH_TRUSTED_ORIGINS="start-ui-native://,start-ui-native://*" # Mobile app scheme for trustedOrigins config

# GITHUB
GITHUB_CLIENT_ID="REPLACE ME"
GITHUB_CLIENT_SECRET="REPLACE ME"

# EMAILS
RESEND_API_KEY="REPLACE ME"
RESEND_WEBHOOK_SECRET="REPLACE ME"
EMAIL_FROM="Start UI <noreply@example.com>"

# LOGGER
LOGGER_LEVEL="info"
LOGGER_CONSOLE_MIRROR="true"
# Legacy LOGGER_PRETTY is accepted as an alias for LOGGER_CONSOLE_MIRROR.

# SENTRY (optional — leave blank to disable)
# SENTRY_DSN=""
# VITE_SENTRY_DSN=""
# SENTRY_ENVIRONMENT=""
# VITE_SENTRY_ENVIRONMENT=""
# SENTRY_ORG="" # Required only for sourcemap upload during `pnpm build`
# SENTRY_PROJECT="" # Required only for sourcemap upload during `pnpm build`
# SENTRY_AUTH_TOKEN="" # Required only for sourcemap upload during `pnpm build`
# VITE_SENTRY_TUNNEL_PATH="/api/telemetry/sentry-tunnel"

# OTEL / OBSERVABILITY (optional)
VITE_OTEL_BROWSER_ENABLED="true"
VITE_OTEL_SERVICE_NAME="start-ui-web"
# VITE_OTEL_SERVICE_VERSION=""
VITE_OTEL_ENVIRONMENT="local"
VITE_OTEL_TRACES_SAMPLE_RATE=1
VITE_TELEMETRY_DEBUG_RAW_VALUES="false"

# Server OTel exports directly to an external Collector when configured.
# Browser telemetry always posts to same-origin /api/telemetry/* routes.
# OTEL_COLLECTOR_URL="http://localhost:${DOCKER_OTEL_COLLECTOR_PORT}"
# OTEL_COLLECTOR_BEARER_TOKEN=""
OTEL_SERVICE_NAME="start-ui-web"
# OTEL_SERVICE_VERSION=""
OTEL_ENVIRONMENT="local"
OTEL_TRACES_SAMPLE_RATE=1
OTEL_LOCAL_SQLITE_ENABLED="true"
OTEL_LOCAL_SQLITE_PATH=".telemetry/telemetry.sqlite"
TELEMETRY_PROXY_MAX_BYTES=1000000
TELEMETRY_LOG_MAX_EVENTS=50

# Collector profile exporters. Required when running:
# docker compose --profile observability up otel-collector
SENTRY_OTLP_ENDPOINT="https://example.ingest.sentry.io/api/project-id/otel"
SENTRY_OTLP_AUTH_HEADER="Bearer REPLACE_ME"
HONEYCOMB_OTLP_ENDPOINT="https://api.honeycomb.io"
HONEYCOMB_API_KEY="REPLACE ME"
HONEYCOMB_DATASET="start-ui-web"
