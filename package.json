    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.6",
    "@electric-sql/pglite-socket": "0.1.6",
    "@eslint-react/eslint-plugin": "^5.8.9",
    "@faker-js/faker": "10.4.0",
    "@fast-check/vitest": "0.4.1",
    "@playwright/test": "1.60.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@softarc/sheriff-core": "^0.19.6",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@svgr/cli": "8.1.0",
    "@tailwindcss/postcss": "4.3.0",
    "@tanstack/devtools-vite": "0.7.0",
    "@tanstack/eslint-plugin-query": "5.100.14",
    "@tanstack/eslint-plugin-router": "1.162.0",
    "@testcontainers/postgresql": "^12.0.1",
    "@types/node": "^24.12.3",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/browser": "4.1.8",
    "@vitest/browser-playwright": "4.1.8",
    "@vitest/coverage-v8": "^4.1.8",
    "babel-plugin-react-compiler": "1.0.0",
    "catching-jit-tests-vitest": "^0.4.0",
    "cross-env": "10.1.0",
    "dependency-cruiser": "^17.4.3",
    "dotenv-cli": "11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.4.1",
    "eslint-plugin-playwright": "^2.10.4",
