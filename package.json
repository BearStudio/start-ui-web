{
  "name": "start-ui-web",
  "version": "3.0.0",
  "private": true,
  "description": "Opinionated UI starter from the 🐻 BearStudio Team",
  "homepage": "https://github.com/bearstudio/start-ui-web#readme",
  "bugs": {
    "url": "https://github.com/bearstudio/start-ui-web/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Ivan Dalmet",
    "email": "ivan@dalmet.fr",
    "url": "https://github.com/ivan-dalmet"
  },
  "contributors": [
    {
      "name": "Yoann Fleury",
      "email": "yoannfleurydev@gmail.com",
      "url": "https://github.com/yoannfleurydev"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bearstudio/start-ui-web.git"
  },
  "type": "module",
  "scripts": {
    "postinstall": "pnpm gen:build-info",
    "prepare": "pnpm lefthook install",
    "dev": "run-p env dev:*",
    "dev:app": "pnpm gen:build-info && vite dev",
    "build": "cross-env NODE_ENV=production run-p env gen:build-info && vite build",
    "start": "dotenv -- node .output/server/index.mjs",
    "env": "run-p env:*",
    "env:client": "dotenv -- node ./run-jiti ./src/env/client.ts",
    "env:server": "dotenv -- node ./run-jiti ./src/env/server.ts",
    "cosmos": "cosmos",
    "cosmos-export": "cosmos-export",
    "format": "oxfmt",
    "lint": "run-p lint:*",
    "lint:oxlint": "oxlint --fix .",
    "lint:ts": "tsc --noEmit",
    "gen:build-info": "dotenv -- node ./run-jiti ./src/features/build-info/script-to-generate-json.ts",
    "gen:icons": "svgr --config-file src/components/icons/svgr.config.cjs src/components/icons/svg-sources && oxfmt src/components/icons/generated",
    "test": "vitest --browser.headless",
    "test:ci": "vitest run",
    "test:ui": "vitest",
    "e2e:setup": "dotenv -- cross-env playwright test --project=setup",
    "e2e": "dotenv -- cross-env playwright test",
    "e2e:ui": "dotenv -- cross-env playwright test --ui",
    "dk:init": "docker compose --profile init up -d",
    "dk:start": "docker compose start",
    "dk:stop": "docker compose stop",
    "dk:clear": "docker compose down --volumes",
    "db:init": "pnpm db:push && pnpm db:seed",
    "db:push": "dotenv -- drizzle-kit push",
    "db:generate": "dotenv -- drizzle-kit generate",
    "db:migrate": "dotenv -- drizzle-kit migrate",
    "db:ui": "dotenv -- drizzle-kit studio",
    "db:seed": "dotenv -- cross-env node ./run-jiti ./drizzle/seed/index.ts"
  },
  "dependencies": {
    "@base-ui/react": "1.4.1",
    "@bearstudio/ui-state": "1.1.0",
    "@better-upload/client": "3.0.18",
    "@better-upload/server": "3.0.18",
    "@fontsource-variable/inter": "5.2.8",
    "@hookform/resolvers": "5.2.2",
    "@neondatabase/serverless": "^1.1.0",
    "@orpc/client": "1.14.0",
    "@orpc/openapi": "1.14.0",
    "@orpc/react-query": "1.14.0",
    "@orpc/server": "1.14.0",
    "@orpc/zod": "1.14.0",
    "@paralleldrive/cuid2": "^3.3.0",
    "@react-email/render": "2.0.8",
    "@t3-oss/env-core": "0.13.11",
    "@tanstack/devtools-vite": "0.6.0",
    "@tanstack/react-devtools": "0.10.2",
    "@tanstack/react-query": "5.100.9",
    "@tanstack/react-query-devtools": "5.100.9",
    "@tanstack/react-router": "1.169.1",
    "@tanstack/react-router-devtools": "1.166.13",
    "@tanstack/react-start": "1.167.62",
    "@tanstack/zod-adapter": "1.166.9",
    "@uidotdev/usehooks": "2.4.1",
    "better-auth": "1.6.9",
    "boring-avatars": "2.0.4",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "colorette": "2.0.20",
    "dayjs": "1.11.20",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "i18next": "26.0.8",
    "i18next-browser-languagedetector": "8.2.1",
    "input-otp": "1.4.2",
    "lucide-react": "1.14.0",
    "next-themes": "0.4.6",
    "nitro": "npm:nitro-nightly@3.0.1-20260501-164602-aee73f19",
    "nodemailer": "8.0.7",
    "pg": "^8.20.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "react": "19.2.5",
    "react-day-picker": "9.14.0",
    "react-dom": "19.2.5",
    "react-email": "^6.0.8",
    "react-error-boundary": "6.1.1",
    "react-hook-form": "7.75.0",
    "react-i18next": "17.0.6",
    "react-merge-refs": "3.0.2",
    "react-textarea-autosize": "8.5.9",
    "react-use-disclosure": "12.0.1",
    "remeda": "2.34.0",
    "sonner": "2.0.7",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.4",
    "ts-pattern": "5.9.0",
    "tw-animate-css": "1.4.0",
    "zod": "4.4.3",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.5",
    "@faker-js/faker": "10.4.0",
    "@playwright/test": "1.59.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@softarc/sheriff-core": "^0.19.6",
    "@svgr/cli": "8.1.0",
    "@tailwindcss/postcss": "4.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/eslint-plugin-query": "5.100.9",
    "@tanstack/eslint-plugin-router": "1.161.6",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "8.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/browser": "4.1.5",
    "@vitest/browser-playwright": "4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "babel-plugin-react-compiler": "1.0.0",
    "cross-env": "10.1.0",
    "dependency-cruiser": "^17.4.0",
    "dotenv-cli": "11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "eslint-plugin-sonarjs": "4.0.3",
    "jiti": "2.6.1",
    "jscpd": "^4.0.9",
    "knip": "^6.11.0",
    "lefthook": "2.1.6",
    "npm-run-all": "4.1.5",
    "oxfmt": "0.47.0",
    "oxlint": "1.62.0",
    "playwright": "1.59.1",
    "react-cosmos": "^7.3.0",
    "react-cosmos-plugin-vite": "^7.3.0",
    "resize-observer-polyfill": "1.5.1",
    "ts-plugin-sort-import-suggestions": "1.0.4",
    "tsx": "^4.21.0",
    "typescript": "6.0.3",
    "vite": "8.0.10",
    "vitest": "4.1.5",
    "vitest-browser-react": "2.2.0"
  },
  "resolutions": {
    "@types/node": "^24"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "body-parser": "1.20.4"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@tailwindcss/oxide",
      "esbuild",
      "lefthook",
      "sharp"
    ]
  },
  "jscpd": {
    "threshold": 0,
    "reporters": [
      "markdown"
    ],
    "ignore": [
      "**/node_modules/**",
      "**/dist/**",
      "**/coverage/**",
      "**/tests/**",
      "**/*.json",
      "**/*.fixture.tsx",
      "**/*.test.ts",
      "**/*.css",
      "**/*.md"
    ],
    "absolute": false
  }
}
