{
  "name": "start-ui-web",
  "version": "4.0.0",
  "private": true,
  "description": "Opinionated TanStack Start starter",
  "homepage": "https://github.com/hbmartin/start-ui-web#readme",
  "bugs": {
    "url": "https://github.com/hbmartin/start-ui-web/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Ivan Dalmet",
    "email": "ivan@dalmet.fr",
    "url": "https://github.com/ivan-dalmet"
  },
  "contributors": [
    {
      "name": "Yoann Fleury",
      "email": "yoannfleurydev@gmail.com",
      "url": "https://github.com/yoannfleurydev"
    },
    {
      "name": "Harold Martin",
      "email": "harold.martin@gmail.com",
      "url": "https://www.linkedin.com/in/harold-martin-98526971/"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hbmartin/start-ui-web.git"
  },
  "type": "module",
  "scripts": {
    "postinstall": "pnpm gen:build-info",
    "prepare": "pnpm lefthook install",
    "dev": "run-p env dev:*",
    "dev:app": "pnpm gen:build-info && vite dev",
    "build": "cross-env NODE_ENV=production run-p env gen:build-info && vite build",
    "start": "dotenv -- node .output/server/index.mjs",
    "env": "run-p env:*",
    "env:client": "dotenv -- node ./run-jiti ./src/platform/env/client.ts",
    "env:server": "dotenv -- node ./run-jiti ./src/modules/kernel/infrastructure/config/server.ts",
    "cosmos": "cosmos",
    "cosmos-export": "cosmos-export",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "format:changed": "node scripts/format-changed.mjs",
    "lint": "oxlint .",
    "lint:eslint": "eslint .",
    "lint:fix": "oxlint --fix .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "depcruise": "depcruise --config .dependency-cruiser.cjs src",
    "architecture:graph": "tsx scripts/generate-module-dependency-graph.ts",
    "architecture:graph:check": "tsx scripts/generate-module-dependency-graph.ts --check",
    "lint:sheriff": "sheriff verify",
    "check:test-layering": "node scripts/check-test-layering.mjs",
    "semgrep": "semgrep scan --config .semgrep.yml --error --quiet",
    "codeql:db": "mkdir -p test-results/codeql && codeql version && codeql pack install .github/codeql/start-ui-web-queries && codeql database create test-results/codeql/start-ui-web-db --language=javascript-typescript --source-root . --codescanning-config .github/codeql/codeql-local-extraction.yml --overwrite",
    "codeql:analyze": "mkdir -p test-results/codeql && db=test-results/codeql/start-ui-web-db; if [ ! -d \"$db\" ]; then echo \"CodeQL database not found at $db. Run pnpm codeql:db to create it before pnpm codeql:analyze.\" >&2; exit 1; fi; codeql version && codeql pack install .github/codeql/start-ui-web-queries && codeql database analyze \"$db\" .github/codeql/start-ui-web-queries/start-ui-web-codeql.qls --format=sarifv2.1.0 --output=test-results/codeql/start-ui-web.sarif --rerun",
    "codeql:test": "mkdir -p test-results/codeql && codeql version && codeql pack install .github/codeql/start-ui-web-queries && codeql test run .github/codeql/start-ui-web-queries/test",
    "check:migrations": "node scripts/check-migration-edits.mjs",
    "security:audit": "pnpm audit --audit-level=high && pnpm security:tanstack && pnpm security:risk-register",
    "security:tanstack": "node scripts/check-tanstack-security.mjs",
    "security:risk-register": "node scripts/check-risk-register.mjs",
    "knip:deps": "dotenv -e .env -e .env.example -- knip --include dependencies,unlisted --no-progress",
    "gen:build-info": "dotenv -- node ./run-jiti ./src/app/build-info/infrastructure/generate-build-info.ts",
    "gen:icons": "svgr --config-file src/platform/components/icons/svgr.config.cjs src/platform/components/icons/svg-sources && oxfmt src/platform/components/icons/generated",
    "test": "vitest run",
    "test:unit": "vitest run --project=unit",
    "test:property": "node scripts/run-property-tests.mjs",
    "test:browser": "vitest run --project=browser",
    "test:integration": "vitest run --project=integration",
    "test:integration:workflow": "vitest run --project=integration workflow.integration.test",
    "test:integration:adapters": "vitest run --project=integration infrastructure/__tests__",
    "test:integration:postgres": "vitest run --config vitest.postgres.config.ts",
    "test:affected": "tsx scripts/affected-tests.ts --run",
    "test:affected:list": "tsx scripts/affected-tests.ts",
    "test:jittest": "jittest catch",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "run-s test:mutation:account test:mutation:auth test:mutation:book test:mutation:genre test:mutation:runtime-config test:mutation:user test:mutation:kernel test:mutation:shared",
    "test:mutation:critical": "run-s test:mutation:auth test:mutation:kernel test:mutation:user test:mutation:book test:mutation:shared",
    "test:mutation:fast": "run-s test:mutation:account:fast test:mutation:auth:fast test:mutation:book:fast test:mutation:genre:fast test:mutation:runtime-config:fast test:mutation:user:fast test:mutation:kernel:fast test:mutation:shared:fast",
    "test:mutation:critical:fast": "run-s test:mutation:auth:fast test:mutation:kernel:fast test:mutation:user:fast test:mutation:book:fast test:mutation:shared:fast",
    "test:mutation:dry": "run-s test:mutation:account:dry test:mutation:auth:dry test:mutation:book:dry test:mutation:genre:dry test:mutation:runtime-config:dry test:mutation:user:dry test:mutation:kernel:dry test:mutation:shared:dry",
    "test:mutation:critical:dry": "run-s test:mutation:auth:dry test:mutation:kernel:dry test:mutation:user:dry test:mutation:book:dry test:mutation:shared:dry",
    "test:mutation:fast:dry": "run-s test:mutation:account:fast:dry test:mutation:auth:fast:dry test:mutation:book:fast:dry test:mutation:genre:fast:dry test:mutation:runtime-config:fast:dry test:mutation:user:fast:dry test:mutation:kernel:fast:dry test:mutation:shared:fast:dry",
    "test:mutation:critical:fast:dry": "run-s test:mutation:auth:fast:dry test:mutation:kernel:fast:dry test:mutation:user:fast:dry test:mutation:book:fast:dry test:mutation:shared:fast:dry",
    "test:mutation:account": "stryker run stryker.account.config.mjs",
    "test:mutation:account:fast": "cross-env STRYKER_FAST=1 stryker run stryker.account.config.mjs",
    "test:mutation:account:dry": "stryker run stryker.account.config.mjs --dryRunOnly",
    "test:mutation:account:fast:dry": "cross-env STRYKER_FAST=1 stryker run stryker.account.config.mjs --dryRunOnly",
    "test:mutation:auth": "stryker run stryker.auth.config.mjs",
    "test:mutation:auth:fast": "cross-env STRYKER_FAST=1 stryker run stryker.auth.config.mjs",
    "test:mutation:auth:dry": "stryker run stryker.auth.config.mjs --dryRunOnly",
    "test:mutation:auth:fast:dry": "cross-env STRYKER_FAST=1 stryker run stryker.auth.config.mjs --dryRunOnly",
    "test:mutation:book": "stryker run stryker.book.config.mjs",
    "test:mutation:book:fast": "cross-env STRYKER_FAST=1 stryker run stryker.book.config.mjs",
    "test:mutation:book:dry": "stryker run stryker.book.config.mjs --dryRunOnly",
    "test:mutation:book:fast:dry": "cross-env STRYKER_FAST=1 stryker run stryker.book.config.mjs --dryRunOnly",
    "test:mutation:genre": "stryker run stryker.genre.config.mjs",
    "test:mutation:genre:fast": "cross-env STRYKER_FAST=1 stryker run stryker.genre.config.mjs",
    "test:mutation:genre:dry": "stryker run stryker.genre.config.mjs --dryRunOnly",
    "test:mutation:genre:fast:dry": "cross-env STRYKER_FAST=1 stryker run stryker.genre.config.mjs --dryRunOnly",
    "test:mutation:runtime-config": "stryker run stryker.runtime-config.config.mjs",
    "test:mutation:runtime-config:fast": "cross-env STRYKER_FAST=1 stryker run stryker.runtime-config.config.mjs",
    "test:mutation:runtime-config:dry": "stryker run stryker.runtime-config.config.mjs --dryRunOnly",
    "test:mutation:runtime-config:fast:dry": "cross-env STRYKER_FAST=1 stryker run stryker.runtime-config.config.mjs --dryRunOnly",
    "test:mutation:user": "stryker run stryker.user.config.mjs",
    "test:mutation:user:fast": "cross-env STRYKER_FAST=1 stryker run stryker.user.config.mjs",
    "test:mutation:user:dry": "stryker run stryker.user.config.mjs --dryRunOnly",
    "test:mutation:user:fast:dry": "cross-env STRYKER_FAST=1 stryker run stryker.user.config.mjs --dryRunOnly",
    "test:mutation:kernel": "stryker run stryker.kernel.config.mjs",
    "test:mutation:kernel:fast": "cross-env STRYKER_FAST=1 stryker run stryker.kernel.config.mjs",
    "test:mutation:kernel:dry": "stryker run stryker.kernel.config.mjs --dryRunOnly",
    "test:mutation:kernel:fast:dry": "cross-env STRYKER_FAST=1 stryker run stryker.kernel.config.mjs --dryRunOnly",
    "test:mutation:shared": "stryker run stryker.shared-only.config.mjs",
    "test:mutation:shared:fast": "cross-env STRYKER_FAST=1 stryker run stryker.shared-only.config.mjs",
    "test:mutation:shared:dry": "stryker run stryker.shared-only.config.mjs --dryRunOnly",
    "test:mutation:shared:fast:dry": "cross-env STRYKER_FAST=1 stryker run stryker.shared-only.config.mjs --dryRunOnly",
    "test:e2e": "dotenv -e .env -e .env.example -- cross-env playwright test",
    "test:e2e:chromium": "pnpm test:e2e --project=chromium",
    "test:e2e:visual": "cross-env VITE_VISUAL_TEST=true pnpm test:e2e --project=chromium tests/e2e/visual",
    "test:e2e:visual:auth": "cross-env VITE_VISUAL_TEST=true pnpm test:e2e --project=chromium tests/e2e/visual/auth.visual.spec.ts",
    "test:e2e:visual:app-shell": "cross-env VITE_VISUAL_TEST=true pnpm test:e2e --project=chromium tests/e2e/visual/app-shell.visual.spec.ts",
    "test:e2e:visual:manager-users": "cross-env VITE_VISUAL_TEST=true pnpm test:e2e --project=chromium tests/e2e/visual/manager-users.visual.spec.ts",
    "test:e2e:visual:update": "pnpm test:e2e:visual --update-snapshots",
    "check": "run-p -n format:check lint lint:eslint typecheck depcruise architecture:graph:check check:test-layering check:migrations semgrep security:audit knip:deps",
    "check:ci": "run-p -n format:check lint lint:eslint typecheck depcruise check:test-layering check:migrations security:audit knip:deps",
    "verify": "pnpm check && pnpm test && pnpm build",
    "verify:task": "node scripts/task-verify.mjs",
    "test:ui": "vitest",
    "e2e:setup": "dotenv -e .env -e .env.example -- cross-env playwright test --project=setup",
    "e2e": "pnpm test:e2e",
    "e2e:ui": "pnpm test:e2e --ui",
    "e2e:db:init": "run-s db:migrate db:seed",
    "e2e:dev": "dotenv -e .env -e .env.example -- cross-env VITE_ENV_NAME=tests EMAIL_DELIVERY_DISABLED=true run-s e2e:db:init dev",
    "e2e:webserver": "pglite-server --db=memory:// --port=54329 --max-connections=16 --run \"pnpm e2e:dev\" --include-database-url --shutdown-timeout=10000",
    "dk:init": "docker compose --profile init up -d",
    "dk:start": "docker compose start",
    "dk:stop": "docker compose stop",
    "dk:clear": "docker compose down --volumes",
    "db:init": "pnpm db:push && pnpm db:seed",
    "db:push": "dotenv -- drizzle-kit push",
    "db:generate": "dotenv -- drizzle-kit generate",
    "db:migrate": "dotenv -- node ./run-jiti ./src/modules/kernel/infrastructure/db/migrate-cli.ts",
    "db:ui": "dotenv -- drizzle-kit studio",
    "db:seed": "dotenv -- cross-env node ./run-jiti ./drizzle/seed/index.ts"
  },
  "dependencies": {
    "@base-ui/react": "1.5.0",
    "@bearstudio/ui-state": "1.1.0",
    "@better-upload/client": "3.0.19",
