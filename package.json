  },
  "engines": {
    "node": "24.x"
  },
  "packageManager": "pnpm@11.9.0",
  "jscpd": {
    "threshold": 0,
    "reporters": [
      "markdown"
    ],
    "ignore": [
      "**/node_modules/**",
      "**/dist/**",
      "**/coverage/**",
      "**/tests/**",
      "**/*.json",
      "**/*.fixture.tsx",
      "**/*.test.ts",
      "**/*.css",
      "**/*.md"
    ],
    "absolute": false
  }
