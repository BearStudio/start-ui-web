    "better-auth": "1.6.19",
    "boring-avatars": "2.0.4",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "i18next": "26.3.1",
    "i18next-browser-languagedetector": "8.2.1",
    "input-otp": "1.4.2",
    "lucide-react": "1.20.0",
    "next-themes": "0.4.6",
    "nitro": "npm:nitro-nightly@3.0.1-20260501-164602-aee73f19",
    "pg": "^8.21.0",
    "react": "19.2.7",
    "react-day-picker": "10.0.1",
